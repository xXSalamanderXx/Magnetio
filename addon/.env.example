# ─── Server ───────────────────────────────────────────────────────────────────
PORT=7000
LOG_LEVEL=info

# ─── Caching ──────────────────────────────────────────────────────────────────
# Redis connection URI. Leave blank to use in-memory cache (dev only).
REDIS_URI=redis://localhost:6379

# ─── Scraper back-end ─────────────────────────────────────────────────────────
# URL of the torrent scraper service that feeds raw torrent records.
SCRAPER_URL=http://localhost:8080

# ─── Metrics ──────────────────────────────────────────────────────────────────
METRICS_USER=admin
METRICS_PASSWORD=changeme

# ─── Debrid API Keys (set in user configuration, not here) ────────────────────
# These are passed per-user in the addon configuration URL.
# Do NOT set them here unless running a single-user private instance.
# REAL_DEBRID_API_KEY=
# PREMIUMIZE_API_KEY=
# ALL_DEBRID_API_KEY=
# DEBRID_LINK_API_KEY=
# EASY_DEBRID_API_KEY=
# OFFCLOUD_API_KEY=
# TORBOX_API_KEY=
# PUTIO_API_KEY=
