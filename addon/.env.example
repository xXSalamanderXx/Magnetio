# ─── Server ───────────────────────────────────────────────────────────────────
PORT=7000
LOG_LEVEL=info

# ─── Caching ──────────────────────────────────────────────────────────────────
# Redis connection URI. Leave blank to use in-memory cache (dev only).
REDIS_URI=redis://localhost:6379

# ─── Scraper back-end ─────────────────────────────────────────────────────────
# URL of the torrent scraper service that feeds raw torrent records.
SCRAPER_URL=http://localhost:8080

# ─── Metrics ──────────────────────────────────────────────────────────────────
METRICS_USER=admin
METRICS_PASSWORD=changeme

# ─── Optional subtitles (OpenSubtitles) ──────────────────────────────────────
# Required to enable the Stremio subtitles resource.
# Create your own API app at OpenSubtitles and provide the API key here.
OPENSUBTITLES_API_KEY=

# Required if you want Magnetio to resolve downloadable subtitle URLs instead
# of returning only direct subtitle file links when the provider exposes them.
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=

# Optional custom user-agent string sent to OpenSubtitles.
# OPENSUBTITLES_USER_AGENT=Magnetio v1.0.0

# ─── Debrid API Keys (set in user configuration, not here) ────────────────────
# These are passed per-user in the addon configuration URL.
# Do NOT set them here unless running a single-user private instance.
# REAL_DEBRID_API_KEY=
# PREMIUMIZE_API_KEY=
# ALL_DEBRID_API_KEY=
# DEBRID_LINK_API_KEY=
# EASY_DEBRID_API_KEY=
# OFFCLOUD_API_KEY=
# TORBOX_API_KEY=
# PUTIO_API_KEY=
