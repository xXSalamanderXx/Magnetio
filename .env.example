PORT=7000
LOG_LEVEL=info
CACHE_TTL_STREAMS=3600

# DuckDNS dynamic DNS (required for external access)
DUCKDNS_TOKEN=your-duckdns-token
DUCKDNS_SUBDOMAIN=magnetio

METRICS_USER=admin
METRICS_PASSWORD=changeme

# Public URL used by the addon when generating absolute subtitle proxy links.
ADDON_PUBLIC_URL=https://your-domain.example

# Optional OpenSubtitles integration for subtitle search and syncing.
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=
OPENSUBTITLES_USER_AGENT=Magnetio v1.0.0

# Optional sync tooling overrides inside the addon container.
# ffsubsync is installed in the addon image by default.
# FFSUBSYNC_PATH=ffsubsync
# ALASS_PATH=alass
SUBTITLE_SYNC_MAX_OFFSET_SECONDS=300
ALASS_SPLIT_PENALTY=10
